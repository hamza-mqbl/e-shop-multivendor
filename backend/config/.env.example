# Copy to backend/config/.env and fill in real values. Never commit the real .env.

PORT=8000
NODE_ENV=development

# Database
MONGO_URL=

# Auth
JWT_SECRET_KEY=
JWT_EXPIRES=7d
ACTIVATION_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (activation + order emails)
SMPT_HOST=
SMPT_PORT=
SMPT_SERVICE=
SMPT_MAIL=
SMPT_PASSWORD=

# ── JazzCash (HTTP POST / Page Redirect) ──
# From your JazzCash sandbox → "Generate Credentials".
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
# Backend URL JazzCash returns the customer to after payment:
JAZZCASH_RETURN_URL=http://localhost:8000/api/v2/jazzcash/callback
# Sandbox page-redirect endpoint (use payments.jazzcash.com.pk in production):
JAZZCASH_POST_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/
# Storefront base URL for post-payment redirects:
CLIENT_URL=http://localhost:3000

# Legacy (no longer used after switching to JazzCash + COD)
# STRIPE_API_KEY=
# STRIPE_SECRET_KEY=
